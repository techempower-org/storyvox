<?xml version="1.0" encoding="utf-8"?>
<!--
  OpenDyslexic — bundled offline font for dyslexia-friendly reading (#992).
  Weighted bottoms and varied letter shapes reduce letter-swapping for some
  dyslexic readers. Licensed under SIL OFL 1.1 (see fonts/OFL-OpenDyslexic.txt).
-->
<font-family xmlns:app="http://schemas.android.com/apk/res-auto">
    <font
        app:fontStyle="normal"
        app:fontWeight="400"
        app:font="@font/opendyslexic_regular" />
    <font
        app:fontStyle="normal"
        app:fontWeight="700"
        app:font="@font/opendyslexic_bold" />
</font-family>
